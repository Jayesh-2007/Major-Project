<% layout("layouts/boilerplatecode") %>

<section class="new-listing-page">
    <header class="new-listing-header">
        <h1 class="new-listing-title">Edit Listing</h1>
        <p class="new-listing-subtitle">Update your listing details before publishing changes.</p>
    </header>

    <form class="listing-form" method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <div class="form-field">
            <label for="title">Title</label>
            <input id="title" type="text" name="listing[title]" value="<%= listing.title %>" required>
        </div>

        <div class="form-field">
            <label for="description">Description</label>
            <textarea id="description" name="listing[description]" rows="4" required><%= listing.description %></textarea>
        </div>

        <div class="form-field">
            <label for="image">Image URL</label>
            <input id="image" type="url" name="listing[image]" value="<%= listing.image %>" required>
        </div>

        <div class="form-grid">
            <div class="form-field">
                <label for="price">Price (INR)</label>
                <input id="price" name="listing[price]" value="<%= listing.price %>" type="number" min="0" required>
            </div>

            <div class="form-field">
                <label for="country">Country</label>
                <input id="country" name="listing[country]" value="<%= listing.country %>" type="text" required>
            </div>
        </div>

        <div class="form-field">
            <label for="location">Location</label>
            <input id="location" type="text" name="listing[location]" value="<%= listing.location %>" required>
        </div>

        <button class="form-submit-btn" type="submit">Save Changes</button>
    </form>
</section>
