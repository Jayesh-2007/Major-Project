<% layout("layouts/boilerplatecode") %>

<section class="new-listing-page">
    <header class="new-listing-header">
        <h1 class="new-listing-title">Add New Listing</h1>
        <p class="new-listing-subtitle">Share a place people will want to discover.</p>
    </header>

    <form class="listing-form" action="/listings" method="POST">
        <div class="form-field">
            <label for="title">Title</label>
            <input id="title" type="text" name="listing[title]" placeholder="Enter title" required>
        </div>

        <div class="form-field">
            <label for="description">Description</label>
            <textarea id="description" name="listing[description]" placeholder="Enter description" rows="4" required></textarea>
        </div>

        <div class="form-field">
            <label for="image">Image URL</label>
            <input id="image" type="url" name="listing[image]" placeholder="https://example.com/image.jpg" required>
        </div>

        <div class="form-grid">
            <div class="form-field">
                <label for="price">Price (INR)</label>
                <input id="price" name="listing[price]" placeholder="2500" type="number" min="0" required>
            </div>

            <div class="form-field">
                <label for="country">Country</label>
                <input id="country" name="listing[country]" placeholder="India" type="text" required>
            </div>
        </div>

        <div class="form-field">
            <label for="location">Location</label>
            <input id="location" type="text" name="listing[location]" placeholder="Goa" required>
        </div>

        <button class="form-submit-btn" type="submit">Create Listing</button>
    </form>
</section>
